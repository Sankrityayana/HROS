{
  "name": "company-hr-os",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --names api,web --prefix \"[{name}]\" --restart-tries 10 --restart-after 1000 \"npm run server\" \"npm run client\"",
    "client": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "server": "node server/index.js",
    "start": "node server/index.js",
    "rank": "node scripts/generate-ranked-output.js",
    "test": "node --test tests",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.5.2",
    "concurrently": "^9.2.0",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "openai": "^5.6.0",
    "vite": "6.3.5",
    "typescript": "^5.8.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "overrides": {
    "rollup": "4.40.2"
  },
  "devDependencies": {
    "rollup": "4.40.2"
  }
}
